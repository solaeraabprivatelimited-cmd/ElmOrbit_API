# 🔒 SECURITY ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# NEVER commit .env to git - add to .gitignore

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE & BACKEND ESSENTIALS
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Environment: development, staging, production
ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════════════════════
# JWT AUTHENTICATION (CRITICAL)
# ═══════════════════════════════════════════════════════════════════════════════

# For HS256 (Development ONLY)
JWT_SECRET_KEY=your-secret-key-min-32-characters-long

# For RS256 (Production - use openssl to generate)
JWT_PUBLIC_KEY=your-public-key-here
JWT_ALGORITHM=HS256  # CHANGE TO RS256 IN PRODUCTION
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ═══════════════════════════════════════════════════════════════════════════════
# OAUTH & SOCIAL LOGIN (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ═══════════════════════════════════════════════════════════════════════════════
# CORS & ORIGIN VALIDATION
# ═══════════════════════════════════════════════════════════════════════════════

# ⚠️ CRITICAL: Set to your exact domain(s) in production
# DO NOT use * with allow_credentials=True
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ═══════════════════════════════════════════════════════════════════════════════
# ENCRYPTION (For sensitive data at rest)
# ═══════════════════════════════════════════════════════════════════════════════

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key

# ═══════════════════════════════════════════════════════════════════════════════
# RATE LIMITING & ABUSE PROTECTION
# ═══════════════════════════════════════════════════════════════════════════════

RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_REQUESTS=1000
RATE_LIMIT_GLOBAL_WINDOW=3600
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

LOG_LEVEL=INFO
AUDIT_LOG_FILE=./logs/audit.log
USE_SYSLOG=false
SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=8001

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS (Security)
# ═══════════════════════════════════════════════════════════════════════════════

ENABLE_DOCS=false
ENABLE_DEBUG_MODE=false
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000

# ═══════════════════════════════════════════════════════════════════════════════
# LEGACY MONITORING (Keep for backward compatibility)
# ═══════════════════════════════════════════════════════════════════════════════

MEDIAPIPE_COMPLEXITY=1
MIN_DETECTION_CONFIDENCE=0.7
TARGET_FPS=15
MAX_OCCUPANCY=4

# Enable debug mode (enables Swagger/OpenAPI docs)
DEBUG_MODE=false

# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────

# Rate limiting - maximum requests per window
MAX_REQUESTS_PER_WINDOW=100

# Rate limiting window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Generate a new CSRF secret with: python -c "import secrets; print(secrets.token_hex(32))"
CSRF_TOKEN_SECRET=8bb6748484d9d745b017b48d8ef5c0109f87f4eee7d96c79f330381b8526e463

# ─────────────────────────────────────────────────────────────
# OPTIONAL: NOTIFICATION SERVICES
# ─────────────────────────────────────────────────────────────

# Email service configuration (for alerts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Webhook URL for alerts (e.g., Slack, Discord)
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ─────────────────────────────────────────────────────────────
# DEPLOYMENT
# ─────────────────────────────────────────────────────────────

# Port to run the API on
PORT=8000

# Host to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Environment: development, staging, production
ENVIRONMENT=development
